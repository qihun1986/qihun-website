---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getData } from '../lib/getData.ts'

const { data: videos } = await getData(
  'videos',
  'title, bvid, link, created_at',
  { order: [['sort_order', true], ['created_at', false]] }
);
---

<BaseLayout title="视频 - 奇魂的小窝">
  <main class="page-main" style="max-width:900px;margin:0 auto;padding:2rem 1.5rem">
    <div class="hero">
      <h1 class="hero-title">🔥 热播视频</h1>
      <p class="hero-sub">精选硬件评测 · 真实数据 · 不信云评测</p>
    </div>

    <div class="video-list" style="display:flex;flex-direction:column;gap:0;background:var(--bg-secondary);border-radius:12px;border:1px solid var(--border);overflow:hidden">
      {videos?.length ? videos.map(video => (
        <a href={video.link} target="_blank" rel="noopener" style="display:block;padding:1rem 1.25rem;text-decoration:none;border-bottom:1px solid var(--border);transition:background 0.2s" class="video-item">
          <div style="display:flex;flex-direction:column;gap:0.5rem">
            <h3 style="color:var(--accent);font-size:0.95rem;line-height:1.5;margin:0;font-weight:500">{video.title}</h3>
            <div style="display:flex;align-items:center;gap:1rem;font-size:0.8rem">
              <span style="color:var(--text-secondary)">{video.created_at ? video.created_at.slice(0,10) : ''}</span>
              <span style="color:var(--text-secondary);margin-left:auto">前往B站观看 →</span>
            </div>
          </div>
        </a>
      )) : <div style="text-align:center;padding:3rem;color:var(--text-secondary)">暂无视频数据</div>}
    </div>
  </main>
  <style>
    .video-item:hover { background: var(--bg-tertiary); }
    .video-item:last-child { border-bottom: none; }
    .video-item:hover h3 { text-decoration: underline; }
    @media (max-width: 640px) {
      .video-item {
        padding: 0.875rem 1rem !important;
      }
      .video-item h3 {
        font-size: 0.875rem !important;
      }
    }
  </style>
</BaseLayout>