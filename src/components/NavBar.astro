---
// 全站导航栏（含B站确认、充电、粉丝群三个弹窗）
---

<header class="nav-header">
  <div class="nav-inner">
    <!-- 左侧：汉堡按钮 + Logo -->
    <div class="left-group">
      <button id="hamburger-btn" class="hamburger mobile-only" aria-label="菜单">☰</button>
      <a href="/" class="nav-logo">
        <img src="/images/logo.png" alt="奇魂的小窝" class="logo-img" />
        <span class="logo-text">奇魂的小窝</span>
      </a>
    </div>

    <!-- 桌面端导航 -->
    <nav class="nav-links desktop-only">
      <a href="/">首页</a>
      <div class="nav-dropdown">
        <span class="dropdown-trigger">硬件榜单 ▾</span>
        <div class="dropdown-menu">
          <a href="/cpu">CPU榜</a>
          <a href="/gpu">显卡榜</a>
          <a href="/hardware">配件行情</a>
        </div>
      </div>
      <div class="nav-dropdown">
        <span class="dropdown-trigger">天梯图 ▾</span>
        <div class="dropdown-menu">
          <a href="/cpu-tier">CPU天梯</a>
          <a href="/gpu-tier">显卡天梯</a>
        </div>
      </div>
      <a href="/videos">视频</a>
      <a href="/about">关于</a>
    </nav>

    <!-- 右侧：B站 / 充电 / 群聊图标 + 文字 -->
    <div class="right-actions">
      <button class="action-icon icon-bili" id="nav-bili-btn" title="B站主页">
        <img src="/images/bilibili.svg" alt="B站" class="bili-svg" />
        <span class="action-label desktop-only">B站主页</span>
      </button>
      <button class="action-icon icon-charge" id="nav-charge-btn" title="充电">
        ⚡
        <span class="action-label desktop-only">充电支持</span>
      </button>
      <button class="action-icon icon-group" id="nav-group-btn" title="粉丝群">
        💬
        <span class="action-label desktop-only">粉丝群</span>
      </button>
    </div>
  </div>

  <!-- 移动端侧滑面板（左滑） -->
  <div id="mobile-overlay" class="mobile-overlay"></div>
  <div id="mobile-panel" class="mobile-panel">
    <div class="mobile-panel-header">
      <span class="mobile-panel-title">导航</span>
      <button id="mobile-panel-close" class="mobile-panel-close">✕</button>
    </div>
    <div class="mobile-panel-body">
      <a href="/">首页</a>
      <a href="/cpu">CPU榜</a>
      <a href="/gpu">显卡榜</a>
      <a href="/hardware">配件行情</a>
      <a href="/cpu-tier">CPU天梯</a>
      <a href="/gpu-tier">显卡天梯</a>
      <a href="/videos">视频</a>
      <a href="/about">关于</a>
    </div>
  </div>

  <!-- ═══════════════ 三个弹窗（全站统一标杆） ═══════════════ -->

  <!-- B站跳转确认弹窗 -->
  <div id="nav-bili-modal" class="modal-overlay">
    <div class="modal-panel" style="max-width:360px">
      <div class="modal-handle"></div>
      <div class="modal-header">
        <h3>📺 即将离开奇魂的小窝</h3>
        <button class="nav-modal-close" aria-label="关闭">×</button>
      </div>
      <div class="modal-body">
        <p class="modal-text">前往 B站主页，更多实测视频等着你</p>
        <div class="modal-btn-group">
          <button class="nav-modal-btn secondary">取消</button>
          <a href="https://space.bilibili.com/3546785037420940" target="_blank" rel="noopener" class="nav-modal-btn primary">去看看</a>
        </div>
      </div>
    </div>
  </div>

  <!-- 充电弹窗 -->
  <div id="nav-charge-modal" class="modal-overlay">
    <div class="modal-panel" style="max-width:400px">
      <div class="modal-handle"></div>
      <div class="modal-header">
        <h3>⚡ 充电支持</h3>
        <button class="nav-modal-close" aria-label="关闭">×</button>
      </div>
      <div class="modal-body">
        <img src="/images/payment.png" alt="充电收款码" class="modal-qr" />
        <p class="modal-text">🍻 谢了兄弟，电量满格，下期实测已经在路上了</p>
      </div>
    </div>
  </div>

  <!-- 粉丝群弹窗 -->
  <div id="nav-group-modal" class="modal-overlay">
    <div class="modal-panel" style="max-width:400px">
      <div class="modal-handle"></div>
      <div class="modal-header">
        <h3>💬 加入粉丝群</h3>
        <button class="nav-modal-close" aria-label="关闭">×</button>
      </div>
      <div class="modal-body">
        <img src="/images/group_qr.png" alt="粉丝群二维码" class="modal-qr" />
        <p class="modal-text">扫码加入粉丝群，一起聊硬件、聊游戏 🔥</p>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-header {
    position: sticky; top: 0; z-index: 100;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-card);
  }
  .nav-inner {
    max-width: 1400px; margin: 0 auto;
    padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 56px; gap: 1rem;
  }

  .left-group { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .nav-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }

  .logo-img {
    height: 36px; width: auto; border-radius: 6px;
    box-shadow: 0 0 8px rgba(0,0,0,0.2), 0 0 16px var(--accent);
    animation: logo-glow 2s ease-in-out infinite alternate;
  }

  @keyframes logo-glow {
    0% { box-shadow: 0 0 8px rgba(0,0,0,0.2), 0 0 16px var(--accent); }
    100% { box-shadow: 0 0 8px rgba(0,0,0,0.2), 0 0 28px var(--accent); }
  }

  .logo-text {
    position: relative;
    font-size: 1.1rem; font-weight: 700; color: var(--accent);
    overflow: hidden;
  }
  .logo-text::after {
    content: '';
    position: absolute; top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.4), transparent);
    animation: shimmer-light 2s ease-in-out infinite alternate;
  }

  @keyframes shimmer-light {
    0% { left: -100%; }
    100% { left: 120%; }
  }

  .nav-links { display: flex; align-items: center; gap: 0.3rem; }
  .nav-links a,
  .dropdown-trigger {
    color: var(--text-secondary); text-decoration: none;
    padding: 6px 14px; border-radius: 8px;
    font-size: 0.95rem; font-weight: 500;
    cursor: pointer; transition: all var(--anim-fast);
    user-select: none;
  }
  .nav-links a:hover,
  .dropdown-trigger:hover {
    background: var(--highlight-bg);
    color: var(--accent);
  }

  .nav-dropdown { position: relative; }
  .dropdown-menu {
    display: none; position: absolute; top: 100%; left: 0;
    margin-top: 8px; min-width: 140px;
    background: var(--bg-secondary); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 6px 0;
    box-shadow: var(--shadow-card); z-index: 200;
  }
  .dropdown-menu.open { display: block; }
  .dropdown-menu a {
    display: block; padding: 10px 18px;
    color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;
    text-decoration: none; border-left: 2px solid transparent;
  }
  .dropdown-menu a:hover {
    background: var(--highlight-bg);
    color: var(--accent);
    border-left-color: var(--accent);
  }

  .hamburger {
    background: none; border: none; color: var(--text-primary);
    font-size: 1.5rem; cursor: pointer;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
  }

  .right-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .action-icon {
    border: none; font-size: 1rem; cursor: pointer;
    min-width: 38px; min-height: 38px;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--radius-md); text-decoration: none;
    transition: all var(--anim-fast);
    gap: 4px;
    padding: 0 10px;
    white-space: nowrap;
  }
  .action-label {
    font-size: 0.8rem;
    font-weight: 500;
  }
  .icon-bili { background: #fb7299; color: #fff; }
  .icon-bili:hover { filter: brightness(1.1); }
  .icon-charge { background: #4a90d9; color: #fff; }
  .icon-charge:hover { filter: brightness(1.1); }
  .icon-group { background: #2dc100; color: #fff; }
  .icon-group:hover { filter: brightness(1.1); }
  .bili-svg { width: 20px; height: 20px; filter: brightness(0) invert(1); }

  .mobile-overlay {
    display: none; position: fixed; inset: 0;
    background: var(--modal-overlay); z-index: 2000;
  }
  .mobile-overlay.show { display: block; }

  .mobile-panel {
    position: fixed; left: 0; top: 0; bottom: 0; width: 280px;
    background: var(--modal-bg); z-index: 2001;
    overflow-y: auto; box-shadow: var(--shadow-modal);
    transform: translateX(-100%); transition: transform var(--anim-normal);
  }
  .mobile-panel.show { transform: translateX(0); }

  .mobile-panel-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem; border-bottom: 1px solid var(--border);
  }
  .mobile-panel-title { color: var(--accent); font-weight: 600; }
  .mobile-panel-close {
    background: none; border: none; color: var(--text-secondary);
    font-size: 1.2rem; cursor: pointer; min-width: 44px; min-height: 44px;
  }
  .mobile-panel-body { padding: 0.5rem 0; }
  .mobile-panel-body a {
    display: block; padding: 0.8rem 1rem;
    color: var(--text-primary); text-decoration: none;
    font-size: 1rem; font-weight: 500;
  }
  .mobile-panel-body a:hover {
    background: var(--highlight-bg);
    color: var(--accent);
  }

  /* ═══════════ 弹窗标杆样式 ═══════════ */
  .modal-overlay {
    position: fixed; inset: 0; background: var(--modal-overlay);
    display: flex; align-items: flex-end; justify-content: center;
    z-index: 3000;
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .modal-overlay.show {
    opacity: 1; visibility: visible; pointer-events: auto;
  }
  .modal-panel {
    background: var(--modal-bg);
    border-radius: 20px 20px 0 0;
    width: 100%; max-height: 85vh; display: flex; flex-direction: column;
    box-shadow: var(--shadow-modal);
    transform: translateY(100%); transition: transform 0.3s ease;
  }
  .modal-overlay.show .modal-panel { transform: translateY(0); }

  .modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.6rem 1rem; border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    background: var(--modal-deal-header-bg);
    border-radius: 20px 20px 0 0;
  }
  .modal-header h3 { color: var(--accent); margin: 0; font-size: 1rem; }

  .modal-handle {
    width: 36px; height: 4px;
    background: var(--modal-handle);
    border-radius: 2px; margin: 8px auto 0;
  }

  .nav-modal-close {
    background: none; border: none; color: var(--text-secondary);
    font-size: 1.4rem; cursor: pointer;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
  }
  .nav-modal-close:active { transform: scale(0.85); color: var(--text-primary); }

  .modal-body { padding: 1.5rem; text-align: center; }
  .modal-text { color: var(--text-secondary); margin-bottom: 1.5rem; }

  .modal-btn-group { display: flex; gap: 0.5rem; }

  .nav-modal-btn {
    flex: 1; padding: 0.65rem; border-radius: 10px;
    font-size: 0.85rem; font-weight: 500; cursor: pointer;
    transition: all 0.15s; text-align: center; text-decoration: none; display: block;
  }
  .nav-modal-btn.secondary {
    background: var(--highlight-bg);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }
  .nav-modal-btn.primary {
    background: var(--accent);
    color: var(--btn-gold-text);
    font-weight: 600; border: none;
  }
  .nav-modal-btn:active { transform: scale(0.95); }

  .modal-qr {
    width: 240px; height: 240px; object-fit: cover;
    border-radius: 12px;
    box-shadow: var(--shadow-card);
    margin-bottom: 1rem;
  }

  @media (min-width: 769px) {
    .modal-overlay { align-items: center; }
    .modal-panel { max-width: 480px; border-radius: 16px; }
  }

  @media (max-width: 768px) {
    .desktop-only { display: none; }
    .mobile-only { display: flex; }
  }
</style>

<script>
  // 桌面端下拉菜单
  document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
    const trigger = dropdown.querySelector('.dropdown-trigger');
    const menu = dropdown.querySelector('.dropdown-menu');
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('.dropdown-menu.open').forEach(m => {
        if (m !== menu) m.classList.remove('open');
      });
      menu.classList.toggle('open');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
  });

  // 移动端侧滑面板
  const hamburger = document.getElementById('hamburger-btn');
  const mobileOverlay = document.getElementById('mobile-overlay');
  const mobilePanel = document.getElementById('mobile-panel');
  const mobileClose = document.getElementById('mobile-panel-close');

  function openPanel() { mobileOverlay.classList.add('show'); mobilePanel.classList.add('show'); }
  function closePanel() { mobileOverlay.classList.remove('show'); mobilePanel.classList.remove('show'); }

  hamburger?.addEventListener('click', openPanel);
  mobileClose?.addEventListener('click', closePanel);
  mobileOverlay?.addEventListener('click', closePanel);

  // ═══════════ 弹窗通用逻辑（对齐全站标杆） ═══════════
  function openModal(modal) {
    modal.classList.add('show');
    history.pushState({ modal: 'open' }, '', window.location.href);
  }
  function closeModal(modal) {
    modal.classList.remove('show');
    const panel = modal.querySelector('.modal-panel');
    if (panel) panel.style.transform = '';
  }
  function bindModal(modalId) {
    const modal = document.getElementById(modalId);
    if (!modal) return;
    const closeBtn = modal.querySelector('.nav-modal-close');
    if (closeBtn) closeBtn.addEventListener('click', () => closeModal(modal));
    const cancelBtn = modal.querySelector('.nav-modal-btn.secondary');
    if (cancelBtn) cancelBtn.addEventListener('click', () => closeModal(modal));
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(modal); });
    const panel = modal.querySelector('.modal-panel');
    if (panel) {
      let startY = 0, movedY = 0;
      panel.addEventListener('touchstart', (e) => { startY = e.touches[0].clientY; });
      panel.addEventListener('touchmove', (e) => {
        movedY = e.touches[0].clientY - startY;
        if (movedY > 0) panel.style.transform = 'translateY(' + movedY + 'px)';
      });
      panel.addEventListener('touchend', () => {
        if (movedY > 120) closeModal(modal);
        else panel.style.transform = '';
        movedY = 0;
      });
    }
    return modal;
  }

  const biliModal = bindModal('nav-bili-modal');
  const chargeModal = bindModal('nav-charge-modal');
  const groupModal = bindModal('nav-group-modal');

  document.getElementById('nav-bili-btn')?.addEventListener('click', () => openModal(biliModal));
  document.getElementById('nav-charge-btn')?.addEventListener('click', () => openModal(chargeModal));
  document.getElementById('nav-group-btn')?.addEventListener('click', () => openModal(groupModal));

  window.addEventListener('popstate', () => {
    [biliModal, chargeModal, groupModal].forEach(modal => {
      if (modal && modal.classList.contains('show')) {
        closeModal(modal);
        history.pushState({ modal: 'open' }, '', window.location.href);
      }
    });
  });
</script>